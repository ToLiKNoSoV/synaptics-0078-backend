#!/usr/bin/env python3

import dbus
import dbus.service
import dbus.mainloop.glib
from gi.repository import GLib
import subprocess
import os
import logging
import pwd
import time
import sys
import threading

dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.StreamHandler(sys.stderr),
        logging.FileHandler('/tmp/synaptics.log')
    ]
)

class SynapticsDevice(dbus.service.Object):
    def __init__(self, bus_name):
        dbus.service.Object.__init__(self, bus_name, '/net/reactivated/Fprint/Device/0')
        self.claimed_user = None
        self.default_user = None
        self.current_finger = None
        self.enrollment_active = False
        self.enrollment_thread = None
        self.verify_active = False
        self.captures = []
        self.verify_state = {}  # состояние verify для разных клиентов

        # Определяем пользователя
        try:
            for u in pwd.getpwall():
                if u.pw_uid >= 1000 and u.pw_uid < 65534:
                    self.default_user = u.pw_name
                    logging.info(f"Default user: {self.default_user}")
                    break
        except Exception as e:
            logging.error(f"Failed to get user: {e}")
            self.default_user = 'tolik'

        logging.info("=================================")
        logging.info("Synaptics 0078 Device initialized")
        logging.info("=================================")

    def _ensure_user_dir(self, user):
        if not user or user == 'root':
            return None
        try:
            pw = pwd.getpwnam(user)
            uid = pw.pw_uid
            gid = pw.pw_gid
            user_dir = f"/var/lib/fprint/{user}"
            os.makedirs(user_dir, mode=0o755, exist_ok=True)
            os.chown(user_dir, uid, gid)
            return user_dir
        except Exception as e:
            logging.error(f"Failed to create directory: {e}")
            return None

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='', out_signature='as')
    def ListEnrolledFingers(self):
        logging.info("ListEnrolledFingers called")
        user = self.claimed_user or self.default_user
        if not user or user == 'root':
            return []
        user_dir = f"/var/lib/fprint/{user}"
        fingers = []
        if os.path.exists(user_dir):
            for f in os.listdir(user_dir):
                if os.path.isfile(os.path.join(user_dir, f)):
                    fingers.append(f)
        return fingers

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='s', out_signature='')
    def Claim(self, username):
        logging.info(f"Claim: {username}")
        if username:
            self.claimed_user = username
        else:
            self.claimed_user = self.default_user

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='', out_signature='')
    def Release(self):
        logging.info("Release called")
        self.claimed_user = None
        self.current_finger = None
        self.verify_active = False

    # ===== ПРАВИЛЬНЫЙ VERIFY (как в fprintd) =====

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='s', out_signature='')
    def VerifyStart(self, finger_name):
        """Асинхронный старт verify"""
        logging.info(f"★★★★★ VerifyStart: {finger_name} ★★★★★")

        # Получаем информацию о клиенте
        sender = self.connection.get_unique_name()

        user = self.claimed_user or self.default_user
        if not user or user == 'root':
            self.VerifyStatus("verify-failed", True)
            return

        enrolled_fingers = self.ListEnrolledFingers()
        if not enrolled_fingers:
            logging.info("No enrolled fingers")
            self.VerifyStatus("verify-failed", True)
            return

        # Сохраняем состояние для этого клиента
        self.verify_state[sender] = {
            'started': False,
            'completed': False,
            'finger': finger_name,
            'user': user,
            'fingers': enrolled_fingers,
            'result': None
        }

        # Запускаем verify в отдельном потоке
        thread = threading.Thread(target=self._do_verify, args=(sender,))
        thread.daemon = True
        thread.start()

    def _do_verify(self, sender):
        """Выполняет verify и отправляет сигнал с результатом"""
        try:
            logging.info(f"Starting capture for {sender}")

            # Захватываем отпечаток
            result = subprocess.run(['/usr/bin/synaptics-capture', 'capture', '10', '1'],
                                  capture_output=True, text=True, timeout=12)

            if result.returncode != 0:
                logging.error(f"Capture failed: {result.stderr}")
                self._verify_complete(sender, False)
                return

            filename = result.stdout.strip()
            if not filename or not os.path.exists(filename):
                logging.error("No file created")
                self._verify_complete(sender, False)
                return

            # Получаем состояние
            state = self.verify_state.get(sender)
            if not state:
                logging.error(f"No state for {sender}")
                os.remove(filename)
                return

            # Сравниваем с каждым зарегистрированным пальцем
            user_dir = f"/var/lib/fprint/{state['user']}"
            match_found = False

            for finger in state['fingers']:
                template_path = os.path.join(user_dir, finger)
                if not os.path.exists(template_path):
                    continue

                logging.info(f"Comparing with {finger}")

                # Используем сравнение через libfprint
                # ВАЖНО: мы должны использовать ту же логику, что и в драйвере
                # Но пока для простоты используем существующий compare
                cmd = ['/usr/bin/synaptics-capture', 'compare', filename, template_path]
                compare_result = subprocess.run(cmd, capture_output=True, text=True)

                if compare_result.returncode == 0 and compare_result.stdout.strip() == 'MATCH':
                    match_found = True
                    break

            os.remove(filename)

            # Отправляем результат сигналом (как в fprintd!)
            self._verify_complete(sender, match_found)

        except subprocess.TimeoutExpired:
            logging.info("Capture timeout")
            self._verify_complete(sender, False)
        except Exception as e:
            logging.error(f"Verify error: {e}")
            self._verify_complete(sender, False)

    def _verify_complete(self, sender, result):
        """Отправляет результат сигналом и завершает verify"""
        logging.info(f"Verify complete for {sender}: {result}")

        state = self.verify_state.get(sender)
        if state:
            state['completed'] = True

        # Отправляем сигнал клиенту (как в fprintd!)
        if result:
            self.VerifyStatus("verify-match", True)
        else:
            self.VerifyStatus("verify-no-match", True)

        # Очищаем состояние
        if sender in self.verify_state:
            del self.verify_state[sender]

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='', out_signature='')
    def VerifyStop(self):
        """Останавливает verify"""
        logging.info("VerifyStop called")
        sender = self.connection.get_unique_name()
        if sender in self.verify_state:
            state = self.verify_state[sender]
            state['completed'] = True
            self.VerifyStatus("verify-failed", True)
            del self.verify_state[sender]

    # Для обратной совместимости (но лучше не использовать)
    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='', out_signature='b')
    def Verify(self):
        logging.warning("Sync Verify called - use VerifyStart instead")
        return False

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='', out_signature='u')
    def GetCapabilities(self):
        return 5  # CAP_VERIFY | CAP_ENROLL

    @dbus.service.method('net.reactivated.Fprint.Device',
                        in_signature='', out_signature='s')
    def GetScanType(self):
        return 'press'

    @dbus.service.signal('net.reactivated.Fprint.Device', signature='sb')
    def VerifyStatus(self, result, done):
        logging.info(f"📢 VerifyStatus: {result}, done={done}")


class FprintManager(dbus.service.Object):
    def __init__(self, bus_name, device):
        self.device = device
        dbus.service.Object.__init__(self, bus_name, '/net/reactivated/Fprint/Manager')
        logging.info("Manager initialized")

    @dbus.service.method('net.reactivated.Fprint.Manager',
                        in_signature='', out_signature='o')
    def GetDefaultDevice(self):
        return '/net/reactivated/Fprint/Device/0'

    @dbus.service.method('net.reactivated.Fprint.Manager',
                        in_signature='ss', out_signature='ao')
    def GetDevices(self, username, application):
        self.device.default_user = username
        return ['/net/reactivated/Fprint/Device/0']


if __name__ == '__main__':
    try:
        bus = dbus.SystemBus()
        name = dbus.service.BusName('net.reactivated.Fprint', bus)
        device = SynapticsDevice(name)
        manager = FprintManager(name, device)
        logging.info("★★★★★ SERVICE READY ★★★★★")
        loop = GLib.MainLoop()
        loop.run()
    except Exception as e:
        logging.error(f"Fatal error: {e}")
        sys.exit(1)
